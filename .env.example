# Local development values — copy this file to .env and fill in real values.
# On Vercel, set these under Project Settings -> Environment Variables instead
# (never commit real secrets to .env or .env.example).

PORT=5000
NODE_ENV=development

# MongoDB Atlas connection string (Atlas Network Access must allow 0.0.0.0/0
# since Vercel functions have no static outbound IP on the standard plan)
# MONGODB_URI=mongodb+srv://<username>:<password>@<cluster-url>/<database-name>

MONGODB_URI=mongodb+srv://laibairfan:123@cluster0.16ycjsd.mongodb.net/admin_server



# Use a long, random string in production (e.g. `openssl rand -hex 32`)
JWT_SECRET=`openssl rand -hex 32`

# Comma-separated list of allowed frontend origins for CORS
CORS_ORIGIN=http://localhost:3000
